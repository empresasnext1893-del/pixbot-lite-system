# Configurações do Banco de Dados MySQL Local
# Substitua 'seu_usuario' e 'sua_senha' pelos dados do seu MySQL
DATABASE_URL=mysql://seu_usuario:sua_senha@localhost:3306/bot_financeiro

# Configurações do Telegram
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI
TELEGRAM_ADMIN_CHAT_ID=SEU_CHAT_ID_AQUI

# Segredo para Cookies/Sessão
JWT_SECRET=SUA_CHAVE_SECRETA_AQUI

# URL onde o sistema vai rodar (se for local, pode ser http://localhost:3000)
VITE_APP_URL=http://localhost:3000

# Ambiente
NODE_ENV=production
PORT=3000
